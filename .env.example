# ── Django ────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL (auth only) ────────────────────────────────
POSTGRES_DB=banyan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Neo4j (primary CRM store) ────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── ClickHouse (analytics events) — disabled for now ─────
# CLICKHOUSE_HOST=clickhouse
# CLICKHOUSE_PORT=9000
# CLICKHOUSE_DB=default
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Redis (Celery broker + Django Channels layer) ─────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic (Phase 11 LLM tagging) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me

# ── CRM Products (comma-separated) ───────────────────────
CRM_PRODUCTS=ProductA,ProductB,ProductC

# ── LinkedIn Scraping ────────────────────────────────────
# Provide your LinkedIn account credentials to enable profile scraping
# on the Import Contacts page. Without these, manual entry is still available.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
