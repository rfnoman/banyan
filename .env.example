# ── Django ────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL (auth only) ────────────────────────────────
POSTGRES_DB=graphcrm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Neo4j (primary CRM store) ────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── ClickHouse (analytics events) ────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Redis (Celery broker + Django Channels layer) ─────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic (Phase 11 LLM tagging) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me

# ── CRM Products (comma-separated) ───────────────────────
CRM_PRODUCTS=ProductA,ProductB,ProductC

# ── Apify (Phase 9) ───────────────────────────────────────
APIFY_API_TOKEN=replace-me
